                            </button>
                        </div>
                    </div>

                    {{-- Sort & Count --}}
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-gray-500">
                            <span x-text="filteredResidences.length" class="font-bold text-orange-500"></span>
                            résultat(s)
