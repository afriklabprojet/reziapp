{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "dom"],
        "types": ["node"],
        "strict": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "outDir": "dist"
    },
    "include": ["tests/e2e/**/*", "playwright.config.ts"],
    "exclude": ["node_modules", "vendor", "dist"]
}
