APP_NAME="Rezi Studio Meublé Faya"
# ⚠️  PRODUCTION : changer les 3 valeurs ci-dessous avant déploiement
APP_ENV=local                    # → production
APP_KEY=                         # → php artisan key:generate
APP_DEBUG=false                  # → false
APP_URL=http://localhost:8000    # → https://rezi.ci

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rezi
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true   # local HTTP peut l'override à false

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=                # → REQUIRED in production — set a strong password
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
# REDIS_SCHEME=tls

# Email — Resend (https://resend.com)
# En développement : MAIL_MAILER=log (pas d'envoi réel)
# En production  : MAIL_MAILER=resend
MAIL_MAILER=log
MAIL_FROM_ADDRESS="contact@rezi.ci"
MAIL_FROM_NAME="${APP_NAME}"

# Clé API Resend — obtenir sur https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Google Maps API Key (cartes, Places, geocoding, Street View, directions)
GOOGLE_MAPS_API_KEY=

# ===== OAuth / Authentification Sociale =====
# Google OAuth (https://console.developers.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Facebook OAuth (https://developers.facebook.com/)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

# ===== Paiement — Jeko (https://jeko.africa) =====
# Obtenir vos clés sur le dashboard Jeko
JEKO_ENABLED=true
JEKO_API_KEY=
JEKO_API_KEY_ID=
JEKO_STORE_ID=
JEKO_WEBHOOK_SECRET=
JEKO_BASE_URL=https://api.jeko.africa
JEKO_CURRENCY=XOF
JEKO_SANDBOX=false             # → MUST be false in production — set true only for local dev/testing
JEKO_CALLBACK_BASE_URL="${APP_URL}"

# ===== Observabilité — Sentry =====
# Crée un projet Laravel sur https://sentry.io et colle la DSN ci-dessous.
# Vide = Sentry désactivé (no-op).
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

VITE_APP_NAME="${APP_NAME}"
VITE_GOOGLE_MAPS_API_KEY="${GOOGLE_MAPS_API_KEY}"

# Broadcasting / Real-time
BROADCAST_CONNECTION=reverb

# Laravel Reverb (Recommended - Self-hosted)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Activer le broadcasting en temps réel (mettre true quand Reverb/Pusher tourne)
VITE_BROADCASTING_ENABLED=false

# Pusher (Alternative - Cloud-based)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ─── Tarification ReziApp ────────────────────────────────────────────────────
# Taxe d'État fixe par réservation (FCFA)
REZI_STATE_TAX=1000
# Commission plateforme sur les propriétaires (0.10 = 10%)
REZI_OWNER_COMMISSION_RATE=0.10
# Retrait minimum (FCFA)
REZI_MIN_WITHDRAWAL=5000
